NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Phase D: 運用アラート用 Discord Webhook (未設定時はアラート無効・logのみ)
DISCORD_WEBHOOK_URL=

# /preview/admin を本番ビルドでも表示する場合 1 を設定 (通常は空)
NEXT_PUBLIC_ENABLE_ADMIN_PREVIEW=

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Rate Limit で信頼する x-forwarded-for の末尾段数 (本番 proxy 段数に合わせる)
TRUSTED_PROXY_HOPS=1

# /admin/* (観測性ダッシュボード) の allowlist。カンマ区切り
OWNER_EMAILS=runbirdgensou@gmail.com

# /admin/ops (Issues / Logs / Uptime) を未ログインのゲストにも read-only 公開する
# フラグ。"true" の時のみ有効。デフォルト false（owner-only）。
# /coming-soon ページに「ゲストとして閲覧する」ボタンが表示される。
# 許可される操作は read-only 相当のみ（Sentry 参照 / Uptime 参照 / Probe 再取得 /
# Sentry cache flush）。書き込み系 API は引き続き owner-only のまま。
GUEST_OPS_ENABLED=false

# Sentry API 連携 (Organization Token)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=shuu-dw
SENTRY_SERVER_PROJECT=boundary-metaverse-server
SENTRY_WEB_PROJECT=boundary-metaverse-web

# =========================
# Health check polling (Phase D-1: boundary 自己監視)
# =========================
# セミコロン区切り。各エントリは service|url|interval_seconds
# interval は最低 30 秒推奨（30 未満は自動で 30 に丸められる）
#
# boundarylabo.com の Express server は /health を実装している
# （Caddy で /api/* と /health* を server:4000 へ proxy）。
# 軽量版 /health を使う。深いヘルスチェックが欲しければ /health/deep に置き換え。
HEALTH_CHECK_TARGETS=boundary|https://boundarylabo.com/health|60
HEALTH_CHECK_ENABLED=true

# Supabase service_role key (health poller の INSERT / ops API の SELECT で必須)
# 既存の SUPABASE_URL を流用。未設定時は NEXT_PUBLIC_SUPABASE_URL にフォールバック。
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# =========================
# TLS 証明書期限チェック (Phase D-1 追加)
# =========================
# Let's Encrypt 証明書の残り日数を定期的に確認し、30 日以下で warn / 7 日以下で error 通知。
# 結果は service_health_checks テーブルに `service=cert:<host>` で保存される。
# カンマ区切りで host 指定（ポートを明示したい場合は host:port）。
CERT_CHECK_TARGETS=boundarylabo.com,ops.boundarylabo.com,portal.boundarylabo.com
# 間隔は時間単位。1 未満は 1 に丸める。既定 24。
CERT_CHECK_INTERVAL_HOURS=24

# =========================
# Sentry rezona 対応 (方針転換後は未設定のまま。将来 rezona 統合時に uncomment)
# =========================
# SENTRY_REZONA_ORG=shuu-dw
# SENTRY_REZONA_PROJECTS=rezona-server,rezona-web
# SENTRY_REZONA_AUTH_TOKEN=sntryu_...  # 共通 SENTRY_AUTH_TOKEN で十分なら省略
#
# 将来 rezona を監視対象に戻す場合、HEALTH_CHECK_TARGETS に追記:
# HEALTH_CHECK_TARGETS=boundary|https://boundarylabo.com/health|60;rezona|https://rezona.example.com/api/health|60

# =========================
# Sentry Activity タブ Deep Link 用 project ID (任意)
# =========================
# Sentry Discover/Issues UI は project クエリパラメータに数値の project ID を要求する。
# (slug を渡すと "Invalid project parameter. Values must be numbers." エラーが発生)
# 取得方法: Sentry Web UI → Settings → Projects → 該当プロジェクト → Project ID
#
# 未設定時はサーバー側で Sentry API (/projects/{org}/{slug}/) から自動 resolve し
# 24h キャッシュする。env で固定すれば API 呼び出し不要 + 確実に動作。
SENTRY_BOUNDARY_SERVER_PROJECT_ID=
SENTRY_BOUNDARY_WEB_PROJECT_ID=
SENTRY_REZONA_SERVER_PROJECT_ID=
SENTRY_REZONA_WEB_PROJECT_ID=

# =========================
# Phase A3: scheduler / アラート / ログ集約 / バックアップ
# =========================

# Cron / scheduled job ランナー。"true" で有効。
# 有効化前に supabase migration 20260428000001_a3_scheduler_tables.sql を適用すること。
JOB_RUNNER_ENABLED=false

# 古いレコードの retention (日数)
ACTIVITY_RETENTION_DAYS=30
HEALTH_RETENTION_DAYS=14

# rezona airdrop dry-run の URL (read-only health check)。未設定時は no-op。
# 例: https://api.rezona.example/admin/airdrop/dry-run
REZONA_AIRDROP_DRYRUN_URL=
REZONA_INTERNAL_SECRET=

# 外部サービス (rezona など) からの pino ログ受信用 Bearer Token。
# 未設定時は /api/logs/ingest が 503 を返す (= 受信無効)。
PORTAL_LOG_INGEST_TOKEN=

# Scaleway TEM SMTP 経由の運用メール送信。
# Username は Scaleway Project ID (UUID)、Password は IAM API Secret Key。
# port 2587 は DigitalOcean からの送信向け (587 はブロックされる)。
SMTP_HOST=smtp.tem.scaleway.com
SMTP_PORT=2587
SMTP_USERNAME=
SMTP_PASSWORD=
OPS_EMAIL_FROM=
OPS_EMAIL_FROM_NAME=Boundary LAB Ops
# カンマ区切りで複数指定可
OPS_EMAIL_TO=

# R2 バックアップ専用バケット (boundary-assets とは別キー推奨)
R2_BACKUP_ENDPOINT=
R2_BACKUP_BUCKET=boundary-backups
R2_BACKUP_ACCESS_KEY_ID=
R2_BACKUP_SECRET_ACCESS_KEY=
R2_BACKUP_REGION=auto
