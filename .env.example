NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Phase D: 運用アラート用 Discord Webhook (未設定時はアラート無効・logのみ)
DISCORD_WEBHOOK_URL=

# /preview/admin を本番ビルドでも表示する場合 1 を設定 (通常は空)
NEXT_PUBLIC_ENABLE_ADMIN_PREVIEW=

# Phase 3a: Reticulum (Hubs Foundation) DB への読み取り専用接続文字列
# 例: postgres://ro_user:pass@reticulum-db.internal:5432/ret_production
# 未設定時は Hubs 情報セクションが「未接続」表示になる
RETICULUM_DB_URL=

# Rate Limit で信頼する x-forwarded-for の末尾段数 (本番 proxy 段数に合わせる)
TRUSTED_PROXY_HOPS=1
